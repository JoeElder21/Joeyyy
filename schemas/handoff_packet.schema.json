{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JoeElder21/Joeyyy/schemas/handoff_packet.schema.json",
  "title": "Specialist Handoff Packet v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "delegation_id",
    "mission_id",
    "resource_id",
    "agent",
    "owner_brain",
    "memory_namespace",
    "invocation_mode",
    "external_actions_performed",
    "status",
    "findings",
    "evidence",
    "tests",
    "assumptions",
    "blockers",
    "challenges",
    "proposed_writes",
    "validation",
    "confidence",
    "sensitivity",
    "recommended_next_handoff"
  ],
  "properties": {
    "schema_version": {"enum": ["2.0", "2.1"]},
    "delegation_id": {"type": ["string", "null"]},
    "mission_id": {"type": "string", "minLength": 1},
    "resource_id": {"type": "string", "minLength": 1},
    "agent": {"type": "string", "minLength": 1},
    "owner_brain": {"enum": ["APEX", "JEOS"]},
    "memory_namespace": {"type": "string", "minLength": 1},
    "invocation_mode": {"enum": ["delegated", "direct_read_only"]},
    "external_actions_performed": {"const": false},
    "status": {"enum": ["completed", "partial", "blocked", "boundary_blocked"]},
    "findings": {"type": "array", "items": {"type": "string"}},
    "mode": {"type": "string", "minLength": 1},
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_type", "records"],
        "properties": {
          "artifact_type": {
            "type": "string",
            "minLength": 1,
            "pattern": "[a-z][a-z0-9_]{0,63}"
          },
          "records": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "record_id",
                "record_type",
                "source_refs",
                "as_of",
                "source_locator",
                "revision",
                "content_hash",
                "fields",
                "confidence"
              ],
              "properties": {
                "record_id": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "[A-Za-z0-9][A-Za-z0-9._:/-]{0,127}"
                },
                "record_type": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "[a-z][a-z0-9_]{0,63}"
                },
                "source_refs": {
                  "type": "array",
                  "items": {"type": "string", "minLength": 1}
                },
                "as_of": {"type": ["string", "null"]},
                "source_locator": {"type": ["string", "null"]},
                "revision": {"type": ["string", "null"]},
                "content_hash": {
                  "type": ["string", "null"],
                  "pattern": "[0-9a-f]{64}"
                },
                "fields": {"type": "object"},
                "confidence": {
                  "enum": ["confirmed", "source-backed", "judgment", "assumption", "unknown"]
                }
              }
            }
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_ref",
          "owner_brain",
          "source_type",
          "scope_verified_by",
          "sensitivity"
        ],
        "properties": {
          "source_ref": {"type": "string", "minLength": 1},
          "owner_brain": {"enum": ["APEX", "JEOS"]},
          "source_type": {
            "enum": ["attachment", "runtime_record", "connector_record", "synthetic", "cross_brain_constraint", "brain_private_constraint"]
          },
          "scope_verified_by": {"const": "apex_chief_of_staff"},
          "sensitivity": {"enum": ["public", "internal", "confidential", "restricted"]}
        }
      }
    },
    "tests": {"type": "array", "items": {"type": "string"}},
    "assumptions": {"type": "array", "items": {"type": "string"}},
    "blockers": {"type": "array", "items": {"type": "string"}},
    "challenges": {"type": "array", "items": {"type": "string"}},
    "proposed_writes": {
      "type": "array",
      "maxItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target",
          "expected_state",
          "validation_readback",
          "rollback",
          "writer_agent",
          "writer_lease_id"
        ],
        "properties": {
          "target": {"type": "string", "minLength": 1},
          "expected_state": {"type": "string", "minLength": 1},
          "validation_readback": {"type": "string", "minLength": 1},
          "rollback": {"type": "string", "minLength": 1},
          "writer_agent": {"type": "string", "minLength": 1},
          "writer_lease_id": {"type": "string", "minLength": 1},
          "operation": {
            "enum": ["append", "upsert", "patch", "replace", "disable"]
          },
          "record_type": {
            "type": "string",
            "minLength": 1,
            "pattern": "[a-z][a-z0-9_]{0,63}"
          },
          "artifact_record_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1,
              "pattern": "[A-Za-z0-9][A-Za-z0-9._:/-]{0,127}"
            }
          },
          "idempotency_key": {
            "type": "string",
            "minLength": 1,
            "pattern": "[A-Za-z0-9][A-Za-z0-9._:/-]{0,127}"
          },
          "expected_version": {"type": ["string", "null"]}
        }
      }
    },
    "validation": {"type": "array", "items": {"type": "string"}},
    "criterion_validation": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["criterion_id", "status", "evidence_record_ids", "note"],
        "properties": {
          "criterion_id": {
            "type": "string",
            "minLength": 1,
            "pattern": "[A-Za-z0-9][A-Za-z0-9._:/-]{0,127}"
          },
          "status": {"enum": ["passed", "failed", "not_tested"]},
          "evidence_record_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "pattern": "[A-Za-z0-9][A-Za-z0-9._:/-]{0,127}"
            }
          },
          "note": {"type": "string"}
        }
      }
    },
    "confidence": {"enum": ["confirmed", "source-backed", "judgment", "assumption", "unknown"]},
    "sensitivity": {"enum": ["public", "internal", "confidential", "restricted"]},
    "recommended_next_handoff": {"type": ["string", "null"]}
  }
}
