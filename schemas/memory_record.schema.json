{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JoeElder21/Joeyyy/schemas/memory_record.schema.json",
  "title": "Brain-Scoped Memory Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_id",
    "mission_id",
    "resource_id",
    "owner_brain",
    "memory_namespace",
    "record_type",
    "content_summary",
    "source_refs",
    "write_target",
    "writer_agent",
    "writer_lease_id",
    "mutation_result_id",
    "created_at",
    "sensitivity",
    "validation_readback",
    "rollback",
    "status"
  ],
  "properties": {
    "schema_version": {"const": "2.0"},
    "record_id": {"type": "string", "minLength": 1},
    "mission_id": {"type": "string", "minLength": 1},
    "resource_id": {"type": "string", "minLength": 1},
    "owner_brain": {"enum": ["APEX", "JEOS"]},
    "memory_namespace": {"type": "string", "minLength": 1},
    "record_type": {"enum": ["fact", "decision", "commitment", "lesson", "hypothesis", "system", "audit"]},
    "content_summary": {"type": "string", "minLength": 1},
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_ref",
          "owner_brain",
          "source_type",
          "scope_verified_by",
          "sensitivity"
        ],
        "properties": {
          "source_ref": {"type": "string", "minLength": 1},
          "owner_brain": {"enum": ["APEX", "JEOS"]},
          "source_type": {
            "enum": ["attachment", "runtime_record", "connector_record", "synthetic", "cross_brain_constraint", "brain_private_constraint"]
          },
          "scope_verified_by": {"const": "apex_chief_of_staff"},
          "sensitivity": {"enum": ["public", "internal", "confidential", "restricted"]}
        }
      }
    },
    "write_target": {"type": "string", "minLength": 1},
    "writer_agent": {"type": "string", "minLength": 1},
    "writer_lease_id": {"type": "string", "minLength": 1},
    "mutation_result_id": {"type": ["string", "null"]},
    "created_at": {"type": "string", "minLength": 1},
    "sensitivity": {"enum": ["public", "internal", "confidential", "restricted"]},
    "validation_readback": {"type": "string", "minLength": 1},
    "rollback": {"type": "string", "minLength": 1},
    "status": {"enum": ["proposed", "written", "superseded", "retracted"]}
  }
}
