{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JoeElder21/Joeyyy/schemas/mutation_result.schema.json",
  "title": "Agent 007 Mutation Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "result_id",
    "mission_id",
    "resource_id",
    "owner_brain",
    "writer_agent",
    "writer_lease_id",
    "write_target",
    "status",
    "expected_state",
    "expected_state_verified",
    "observed_state",
    "readback_evidence",
    "verified_at",
    "rollback_method",
    "rollback_test_status",
    "rollback_evidence",
    "error",
    "sensitivity"
  ],
  "properties": {
    "schema_version": {"const": "2.0"},
    "result_id": {"type": "string", "minLength": 1},
    "mission_id": {"type": "string", "minLength": 1},
    "resource_id": {"type": "string", "minLength": 1},
    "owner_brain": {"enum": ["APEX", "JEOS"]},
    "writer_agent": {"type": "string", "minLength": 1},
    "writer_lease_id": {"type": "string", "minLength": 1},
    "write_target": {"type": "string", "minLength": 1},
    "status": {"enum": ["attempted", "failed", "written", "verified", "rolled_back"]},
    "expected_state": {"type": "string", "minLength": 1},
    "expected_state_verified": {"type": ["boolean", "null"]},
    "observed_state": {"type": ["string", "null"]},
    "readback_evidence": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "verified_at": {"type": ["string", "null"]},
    "rollback_method": {"type": "string", "minLength": 1},
    "rollback_test_status": {"enum": ["not_tested", "verified", "failed", "not_applicable"]},
    "rollback_evidence": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "error": {"type": ["string", "null"]},
    "sensitivity": {"enum": ["public", "internal", "confidential", "restricted"]}
  }
}
