{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JoeElder21/Joeyyy/schemas/roundtable_memo.schema.json",
  "title": "Brain-Private Specialist Roundtable Memo v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "memo_id",
    "delegation_id",
    "mission_id",
    "timestamp",
    "owner_brain",
    "roundtable_namespace",
    "resource_id",
    "from_agent",
    "to_agents",
    "subject",
    "message_type",
    "evidence",
    "confidence",
    "writer_agent",
    "writer_lease_id",
    "write_target",
    "status",
    "approval_level",
    "sensitivity",
    "resolution"
  ],
  "properties": {
    "schema_version": {"const": "2.0"},
    "memo_id": {"type": "string", "minLength": 1},
    "delegation_id": {"type": "string", "minLength": 1},
    "mission_id": {"type": "string", "minLength": 1},
    "timestamp": {"type": "string", "minLength": 1},
    "owner_brain": {"enum": ["APEX", "JEOS"]},
    "roundtable_namespace": {"type": "string", "minLength": 1},
    "resource_id": {"type": "string", "minLength": 1},
    "from_agent": {"type": "string", "minLength": 1},
    "to_agents": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "subject": {"type": "string", "minLength": 1},
    "message_type": {"enum": ["ask", "challenge", "handoff", "information", "conflict"]},
    "body": {"type": "string"},
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_ref",
          "owner_brain",
          "source_type",
          "scope_verified_by",
          "sensitivity"
        ],
        "properties": {
          "source_ref": {"type": "string", "minLength": 1},
          "owner_brain": {"enum": ["APEX", "JEOS"]},
          "source_type": {
            "enum": ["attachment", "runtime_record", "connector_record", "synthetic", "cross_brain_constraint", "brain_private_constraint"]
          },
          "scope_verified_by": {"const": "apex_chief_of_staff"},
          "sensitivity": {"enum": ["public", "internal", "confidential", "restricted"]}
        }
      }
    },
    "confidence": {"enum": ["confirmed", "source-backed", "judgment", "assumption", "unknown"]},
    "owner": {"type": ["string", "null"]},
    "due": {"type": ["string", "null"]},
    "writer_agent": {"type": ["string", "null"]},
    "writer_lease_id": {"type": ["string", "null"]},
    "write_target": {"type": ["string", "null"]},
    "status": {"enum": ["open", "acknowledged", "resolved", "blocked"]},
    "approval_level": {"enum": ["L0", "L1", "L2", "L3", "L4"]},
    "sensitivity": {"enum": ["public", "internal", "confidential", "restricted"]},
    "resolution": {"type": ["string", "null"]},
    "tags": {"type": "array", "items": {"type": "string"}}
  }
}
